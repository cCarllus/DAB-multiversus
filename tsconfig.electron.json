{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node", "electron"],
    "isolatedModules": false,
    "noEmit": false,
    "rootDir": "app",
    "outDir": "dist-electron",
    "sourceMap": true
  },
  "include": ["app/desktop/**/*.ts", "app/shared/**/*.ts"],
  "exclude": [
    "app/frontend/**/*",
    "app/game/**/*",
    "app/shared/i18n/**/*"
  ]
}
