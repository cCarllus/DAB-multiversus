{
  "name": "dead-as-battle-multiversus",
  "productName": "Dead As Battle",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop-first Babylon.js + Electron foundation for Dead As Battle Multiversus.",
  "main": "dist-electron/desktop/main/index.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "clean": "rimraf dist dist-electron dist-backend release",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:full": "concurrently -k \"npm:dev:backend\" \"npm:dev\"",
    "dev:renderer": "vite",
    "dev:backend": "tsx watch --tsconfig tsconfig.backend.json app/backend/index.ts",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 dist-electron/desktop/main/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node scripts/run-electron-dev.cjs .",
    "build": "npm run clean && npm run build:renderer && npm run build:electron && npm run build:backend",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:backend": "tsc -p tsconfig.backend.json",
    "start:backend": "node dist-backend/app/backend/index.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json && tsc --noEmit -p tsconfig.backend.json && tsc --noEmit -p tsconfig.node.json",
    "format": "prettier --write .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.deadasbattle.multiversus",
    "productName": "Dead As Battle",
    "asar": true,
    "extraResources": [
      {
        "from": "app/frontend/assets/images/ui/icons/icon-desktop-game.png",
        "to": "icons/icon-desktop-game.png"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "config/electron/build-resources",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.games",
      "icon": "config/electron/build-resources/icon-desktop-game.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "config/electron/build-resources/icon-desktop-game.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "config/electron/build-resources/icon-desktop-game.png",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@babylonjs/core": "^9.0.0",
    "@babylonjs/gui": "^9.0.0",
    "@babylonjs/loaders": "^9.0.0",
    "@babylonjs/materials": "^9.0.0",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babylonjs/inspector": "^9.0.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  }
}
