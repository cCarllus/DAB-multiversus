  "loading": {
    "screenAriaLabel": "Loading screen",
    "defaultTitle": "Loading",
    "sequences": {
      "loginToMenu": {
        "eyebrow": "Secure Session Link",
        "title": "Loading launcher",
        "steps": [
          {
            "detail": "JWT access link accepted",
            "holdMs": 220,
            "progress": 0.18,
            "status": "Linking the authenticated session"
          },
          {
            "detail": "Launcher shell and navigation",
            "holdMs": 260,
            "progress": 0.42,
            "status": "Building the main interface"
          },
          {
            "detail": "Background scene and profile modules",
            "holdMs": 320,
            "progress": 0.74,
            "status": "Loading the initial menu assets"
          },
          {
            "detail": "The proving grounds are ready",
            "holdMs": 200,
            "progress": 1,
            "status": "Access cleared for the menu"
          }
        ]
      },
      "resumeToMenu": {
        "eyebrow": "Remembered Device",
        "title": "Restoring launcher",
        "steps": [
          {
            "detail": "Refresh token rotated successfully",
            "holdMs": 180,
            "progress": 0.28,
            "status": "Revalidating the saved session"
          },
          {
            "detail": "Rehydrating launcher state",
            "holdMs": 220,
            "progress": 0.66,
            "status": "Rebuilding the menu modules"
          },
          {
            "detail": "Returning to the proving grounds",
            "holdMs": 170,
            "progress": 1,
            "status": "Authenticated access restored"
          }
        ]
      },
      "menuToGame": {
        "eyebrow": "Arena Deployment",
        "title": "Loading battle",
        "steps": [
          {
            "detail": "Champion slot and arena sigils",
            "holdMs": 240,
            "progress": 0.18,
            "status": "Locking the match configuration"
          },
          {
            "detail": "Combat shell and match bridge",
            "holdMs": 280,
            "progress": 0.44,
            "status": "Synchronizing the game handoff"
          },
          {
            "detail": "Streaming battle-side assets",
            "holdMs": 320,
            "progress": 0.78,
            "status": "Loading the initial arena assets"
          },
          {
            "detail": "Arena ready for deployment",
            "holdMs": 220,
            "progress": 1,
            "status": "The arena is ready"
          }
        ]
      },
      "gameToMenu": {
        "eyebrow": "Launcher Recall",
        "title": "Returning to menu",
        "steps": [
          {
            "detail": "Detaching battle shell",
            "holdMs": 180,
            "progress": 0.32,
            "status": "Finishing the game transition"
          },
          {
            "detail": "Rehydrating launcher chrome",
            "holdMs": 220,
            "progress": 0.72,
            "status": "Restoring the main menu"
          },
          {
            "detail": "Menu ready",
            "holdMs": 180,
            "progress": 1,
            "status": "Menu ready again"
          }
        ]
      }
    }
  },
